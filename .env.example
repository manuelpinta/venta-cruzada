# Copia a `.env.local` y rellena desde Supabase → Project Settings → API (o API Keys).
#
# IMPORTANTE (frontend / Vite):
# - Usa la URL del proyecto + la clave PÚBLICA (publishable o legacy "anon").
# - NO pongas aquí la "secret key" / service_role: se expondría en el bundle del navegador.

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Una de las dos (la que te muestre el dashboard):
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Botón "Ayuda" en la cabecera (portal de tickets / soporte). Preferido en Vite:
# VITE_SUPPORT_URL=https://ejemplo.com/soporte
# Compat (mismo efecto): NEXT_PUBLIC_SUPPORT_URL=https://ejemplo.com/soporte

# --- Local real (MySQL) sin Vercel: `npm run dev` levanta Vite + server/dev-api.ts ---
# MYSQL_* sin prefijo VITE_ (solo las lee el proceso Node del API local):
# MYSQL_HOST=tu-servidor
# MYSQL_PORT=6490
# MYSQL_USER=...
# MYSQL_PASSWORD=...
# Pintacomex / Gallco (antes un solo MX; pubpinta suele ir con PC):
# MYSQL_DB_PC=pubpinta
# MYSQL_DB_GC=nombre_base_gallco
# MYSQL_DB_MX=pubpinta
# (compat) si MYSQL_DB_PC no está, se usa MYSQL_DB_MX para PC
# MYSQL_DB_HN=pubhonduras
# MYSQL_DB_BZ=pubbelice
# MYSQL_DB_SV=pubsalvador
# PRODUCTOS_TABLE=producto
# PRODUCTOS_ID_COL=CveAsoc
# PRODUCTOS_NOMBRE_COL=DescripLar
# Solo IdCanRefLista = 0 es producto vigente; el resto se excluye del catálogo.
# PRODUCTOS_ACTIVO_COL=IdCanRefLista
# CATALOG_DEV_API_PORT=8787

# Solo UI con datos mock (sin levantar el API local):
# VITE_CATALOG_USE_MOCK=true
# (o usa: npm run dev:client)

# Catálogo en otro host (preview, otro equipo):
# VITE_CATALOG_API_URL=https://tu-proyecto.vercel.app

# Opcional: VITE_CATALOG_SKU_FIELD=CveAsoc
# VITE_CATALOG_NAME_FIELD=DescripLar
# Caché de búsqueda catálogo en el navegador (ms; 0 = sin caché). Logs: consola [catalog search] en dev.
# VITE_CATALOG_SEARCH_CACHE_TTL_MS=300000
# VITE_CATALOG_SEARCH_LOG=true
